{
  "colors": {
    "background": "#FDFCFB",
    "foreground": "#1A1C1B",
    "surface": "#F8F7F4",
    "surface-elevated": "#FFFFFF",
    "muted-foreground": "#444845",
    "border": "#E2E1DD",
    "border-strong": "#747975",
    "brand": "#0A2E1F",
    "brand-strong": "#051A12",
    "brand-foreground": "#FFFFFF",
    "brand-muted": "#A7D1C1",
    "accent": "#D4A017",
    "success": "#0A2E1F",
    "success-soft": "#D1E1D9",
    "warning": "#D4A017",
    "warning-soft": "#F0C75E",
    "danger": "#BA1A1A",
    "danger-soft": "#FFDAD6",
    "info": "#2A3B4F",
    "info-soft": "#BDC8D9",
    "table-hover": "#F8F7F4"
  },
  "fontFamily": {
    "sans": [
      "Inter",
      "sans-serif"
    ],
    "heading": [
      "Cormorant Garamond",
      "serif"
    ]
  },
  "fontSize": {
    "display-lg": [
      "clamp(3.25rem, 8vw, 7rem)",
      {
        "lineHeight": "0.95",
        "letterSpacing": "-0.04em",
        "fontWeight": "600"
      }
    ],
    "display-md": [
      "clamp(2.25rem, 5vw, 4.75rem)",
      {
        "lineHeight": "1",
        "letterSpacing": "-0.035em",
        "fontWeight": "600"
      }
    ],
    "headline-sm": [
      "clamp(1.35rem, 2.2vw, 2rem)",
      {
        "lineHeight": "1.1",
        "letterSpacing": "-0.02em",
        "fontWeight": "500"
      }
    ],
    "body-lg": [
      "clamp(1rem, 1.2vw, 1.125rem)",
      {
        "lineHeight": "1.65",
        "fontWeight": "400"
      }
    ],
    "body-md": [
      "1rem",
      {
        "lineHeight": "1.6",
        "fontWeight": "400"
      }
    ],
    "body-sm": [
      "0.875rem",
      {
        "lineHeight": "1.5",
        "fontWeight": "400"
      }
    ],
    "label-md": [
      "0.75rem",
      {
        "lineHeight": "1.25rem",
        "letterSpacing": "0.12em",
        "fontWeight": "600"
      }
    ],
    "tabular": [
      "14px",
      {
        "lineHeight": "20px",
        "fontWeight": "500"
      }
    ]
  },
  "spacing": {
    "base": "4px",
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "40px",
    "gutter": "20px",
    "margin": "32px"
  },
  "borderRadius": {
    "none": "0",
    "sm": "2px",
    "DEFAULT": "4px",
    "md": "4px",
    "lg": "8px",
    "full": "9999px"
  },
  "boxShadow": {
    "soft": "0 2px 8px rgba(0, 0, 0, 0.04)",
    "overlay": "0 4px 12px rgba(10, 46, 31, 0.05)"
  },
  "componentPrimitives": {
    "appShell": {
      "background": "background",
      "text": "foreground",
      "contentMaxWidth": "96rem"
    },
    "dataTable": {
      "container": "surface-elevated",
      "border": "border",
      "header": "surface",
      "rowHover": "table-hover"
    },
    "statusBadge": {
      "radius": "sm",
      "success": "success-soft",
      "warning": "warning-soft",
      "danger": "danger-soft",
      "info": "info-soft"
    },
    "metricCard": {
      "surface": "surface-elevated",
      "signalDefault": "brand",
      "signalWarning": "warning",
      "signalSuccess": "success"
    }
  }
}
